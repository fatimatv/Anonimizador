# Runtime
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
API_PORT=3001

# Auth placeholders. Replace before using outside local development.
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=anonimizador_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=900
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD_HASH=replace-with-argon2id-hash

# Database
DATABASE_URL=postgresql://anonimizador:anonimizador_dev_password@localhost:5432/anonimizador?schema=public
POSTGRES_USER=anonimizador
POSTGRES_PASSWORD=anonimizador_dev_password
POSTGRES_DB=anonimizador

# Redis / queue
REDIS_URL=redis://localhost:6379

# Temporary storage
TEMP_STORAGE_ROOT=./tmp-storage
TEMP_FILE_TTL_MINUTES=60
MAX_BATCH_FILES=20
MAX_FILE_SIZE_MB=20

# Security
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUDIT_HASH_SECRET=replace-with-a-separate-audit-hash-secret
